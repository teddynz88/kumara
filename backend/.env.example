# Kūmara backend configuration — copy to .env and fill in.
# .env is gitignored; never commit real values.

# Claude API key (required for AI extraction + plan generation).
# Same key you use in Vercel. Server-side only — never in frontend code.
ANTHROPIC_API_KEY=sk-ant-...

# Claude model for extraction/generation. Defaults to claude-opus-4-8.
# KUMARA_AI_MODEL=claude-opus-4-8

# Supabase project — same values as frontend/.env (the anon key is fine;
# the backend only reads the recipe library and targets with it).
SUPABASE_URL=https://yxzbwbtwvdemkiiijcpa.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Frontend origin allowed by CORS (Vite dev server default).
FRONTEND_ORIGIN=http://localhost:5173
